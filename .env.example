# ========= Development (vite dev) =========
# Leave empty so the frontend uses same-origin /api/* paths and lets
# the vite dev server proxy requests to the backend.
VITE_API_BASE=

# vite dev server proxy target. This is only read by vite dev and is
# not bundled into the frontend.
VITE_PROXY_TARGET=http://localhost:8080

# ========= Production (vite build) =========
# Keep VITE_API_BASE empty and configure the reverse proxy instead.
# For Vercel, set BACKEND_URL in the project environment variables and
# let vercel.ts proxy /api/:path* to the real backend.
# For Cloudflare Pages, set BACKEND_URL in Pages project variables and
# let Pages Functions proxy /api/* to the Workers backend.
# VITE_API_BASE=
BACKEND_URL=https://website-api.1255542159.workers.dev
